# Copy this file to .env for local Docker Compose runs.
# Keep .env private and choose local-only values.

SECRET_KEY=replace_with_local_django_secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django_backend
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1
CORS_ALLOW_ALL_ORIGINS=False

MONGO_ROOT_USERNAME=health_admin
MONGO_ROOT_PASSWORD=replace_with_local_mongo_secret
MONGO_DATABASE=health_data
